# Copy this file to `.env.runtime` and replace the placeholder values.

JWT_SECRET=replace-with-a-random-32-plus-character-secret

# Optional but recommended: keep runtime data outside the git worktree.
# Replace these with absolute paths for the current machine.
CLASSMANAGER_DB_PATH=/home/your-user/.local/state/classmanager-multi/database/classmanager.db
CLASSMANAGER_BACKUP_DIR=/home/your-user/.local/state/classmanager-multi/backups/sqlite
CLASSMANAGER_RUNTIME_DIR=/home/your-user/.local/state/classmanager-multi/runtime
CLASSMANAGER_ALERT_DIR=/home/your-user/.local/state/classmanager-multi/alerts
CLASSMANAGER_RECOVERY_DIR=/home/your-user/.local/state/classmanager-multi/recovery

PORT=3002
