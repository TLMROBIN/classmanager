generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TenantStatus {
  active
  suspended
  archived
}

enum UserStatus {
  active
  disabled
  invited
}

enum MembershipStatus {
  active
  disabled
  invited
}

enum ClassStatus {
  active
  archived
}

enum TransactionType {
  bonus
  penalty
  adjustment
  reward
  refund
}

enum AttendanceRecordStatus {
  present
  late
  absent
  excused
}

enum AttendanceSessionStatus {
  open
  closed
  archived
}

model Tenant {
  id          String       @id @default(uuid()) @db.Uuid
  name        String       @db.VarChar(120)
  slug        String       @unique @db.VarChar(80)
  type        String       @db.VarChar(30)
  status      TenantStatus @default(active)
  planCode    String?      @map("plan_code") @db.VarChar(50)
  ownerUserId String?      @map("owner_user_id") @db.Uuid
  createdAt   DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)

  classes       Class[]
  students      Student[]
  memberships   Membership[]
  roles         Role[]
  groups        Group[]
  dormitories   Dormitory[]
  positions     Position[]
  studentGroups StudentGroupAssignment[]
  studentDorms  StudentDormAssignment[]
  studentRoles  StudentPositionAssignment[]
  pointAccounts PointAccount[]
  pointReasons  PointReasonTemplate[]
  pointTxs      PointTransaction[]
  schedules     AttendanceSchedule[]
  sessions      AttendanceSession[]
  records       AttendanceRecord[]
  policies      AttendancePolicy[]
  configs       ClassConfig[]
  flags         FeatureFlag[]
  audits        AuditLog[]
  importJobs    ImportJob[]
  exportJobs    ExportJob[]
  mappings      MigrationMapping[]

  @@map("tenants")
}

model User {
  id           String      @id @default(uuid()) @db.Uuid
  username     String      @unique @db.VarChar(50)
  email        String?     @unique @db.VarChar(255)
  passwordHash String      @map("password_hash") @db.VarChar(255)
  displayName  String?     @map("display_name") @db.VarChar(120)
  status       UserStatus  @default(active)
  lastLoginAt  DateTime?   @map("last_login_at") @db.Timestamptz(6)
  createdAt    DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime    @updatedAt @map("updated_at") @db.Timestamptz(6)

  memberships   Membership[]
  pointTxs      PointTransaction[] @relation("PointTransactionActorUser")
  records       AttendanceRecord[] @relation("AttendanceRecordActorUser")
  audits        AuditLog[]
  importJobs    ImportJob[]
  exportJobs    ExportJob[]        @relation("ExportJobRequestedByUser")

  @@map("users")
}

model Role {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String?  @map("tenant_id") @db.Uuid
  code       String   @db.VarChar(50)
  name       String   @db.VarChar(120)
  scope      String   @db.VarChar(30)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant          Tenant?           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  membershipRoles MembershipRole[]

  @@unique([tenantId, code])
  @@map("roles")
}

model Membership {
  id          String           @id @default(uuid()) @db.Uuid
  tenantId    String           @map("tenant_id") @db.Uuid
  userId      String           @map("user_id") @db.Uuid
  displayName String?          @map("display_name") @db.VarChar(120)
  status      MembershipStatus @default(active)
  joinedAt    DateTime         @default(now()) @map("joined_at") @db.Timestamptz(6)
  createdAt   DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  roles      MembershipRole[]
  pointTxs   PointTransaction[] @relation("PointTransactionActorMembership")
  records    AttendanceRecord[] @relation("AttendanceRecordActorMembership")
  auditLogs  AuditLog[]
  exportJobs ExportJob[]

  @@unique([tenantId, userId])
  @@map("memberships")
}

model MembershipRole {
  membershipId String   @map("membership_id") @db.Uuid
  roleId       String   @map("role_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  membership Membership @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([membershipId, roleId])
  @@map("membership_roles")
}

model Class {
  id           String      @id @default(uuid()) @db.Uuid
  tenantId     String      @map("tenant_id") @db.Uuid
  name         String      @db.VarChar(120)
  code         String?     @db.VarChar(50)
  status       ClassStatus @default(active)
  gradeLabel   String?     @map("grade_label") @db.VarChar(50)
  academicYear String?     @map("academic_year") @db.VarChar(30)
  timezone     String      @default("Asia/Shanghai") @db.VarChar(50)
  createdAt    DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime    @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant      Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  students    Student[]
  groups      Group[]
  dormitories Dormitory[]
  positions   Position[]
  reasons     PointReasonTemplate[]
  txs         PointTransaction[]
  schedules   AttendanceSchedule[]
  sessions    AttendanceSession[]
  records     AttendanceRecord[]
  policy      AttendancePolicy?
  config      ClassConfig?
  flags       FeatureFlag[]
  audits      AuditLog[]
  importJobs  ImportJob[]
  exportJobs  ExportJob[]

  @@unique([tenantId, name])
  @@map("classes")
}

model Student {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  classId   String   @map("class_id") @db.Uuid
  legacyId  BigInt?  @map("legacy_id")
  studentNo String?  @map("student_no") @db.VarChar(50)
  name      String   @db.VarChar(120)
  gender    String?  @db.VarChar(10)
  status    String   @default("active") @db.VarChar(30)
  joinedAt  DateTime? @map("joined_at") @db.Date
  leftAt    DateTime? @map("left_at") @db.Date
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant    Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  class     Class  @relation(fields: [classId], references: [id], onDelete: Cascade)
  profile   StudentProfile?
  account   PointAccount?
  txs       PointTransaction[]
  records   AttendanceRecord[]
  groups    StudentGroupAssignment[]
  dorms     StudentDormAssignment[]
  positions StudentPositionAssignment[]

  @@unique([classId, legacyId])
  @@unique([classId, studentNo])
  @@index([classId, name])
  @@map("students")
}

model StudentProfile {
  studentId            String   @id @map("student_id") @db.Uuid
  avatarAssetId        String?  @map("avatar_asset_id") @db.Uuid
  avatarHappyAssetId   String?  @map("avatar_happy_asset_id") @db.Uuid
  avatarNormalAssetId  String?  @map("avatar_normal_asset_id") @db.Uuid
  avatarSadAssetId     String?  @map("avatar_sad_asset_id") @db.Uuid
  titleLeft            String?  @map("title_left") @db.VarChar(120)
  titleRight           String?  @map("title_right") @db.VarChar(120)
  notes                String?
  createdAt            DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@map("student_profiles")
}

model Group {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  classId      String   @map("class_id") @db.Uuid
  legacyKey    String?  @map("legacy_key") @db.VarChar(100)
  name         String   @db.VarChar(120)
  colorToken   String?  @map("color_token") @db.VarChar(120)
  displayOrder Int      @default(0) @map("display_order")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant  Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  class   Class  @relation(fields: [classId], references: [id], onDelete: Cascade)
  members StudentGroupAssignment[]

  @@unique([classId, legacyKey])
  @@unique([classId, name])
  @@map("groups")
}

model Dormitory {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  classId      String   @map("class_id") @db.Uuid
  legacyKey    String?  @map("legacy_key") @db.VarChar(100)
  name         String   @db.VarChar(120)
  building     String?  @db.VarChar(120)
  genderScope  String?  @map("gender_scope") @db.VarChar(20)
  displayOrder Int      @default(0) @map("display_order")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant  Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  class   Class  @relation(fields: [classId], references: [id], onDelete: Cascade)
  members StudentDormAssignment[]

  @@unique([classId, legacyKey])
  @@unique([classId, name])
  @@map("dormitories")
}

model Position {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  classId      String?  @map("class_id") @db.Uuid
  code         String   @db.VarChar(80)
  name         String   @db.VarChar(120)
  category     String   @db.VarChar(50)
  displayOrder Int      @default(0) @map("display_order")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant  Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  class   Class? @relation(fields: [classId], references: [id], onDelete: Cascade)
  holders StudentPositionAssignment[]

  @@unique([classId, code])
  @@map("positions")
}

model StudentGroupAssignment {
  id         String    @id @default(uuid()) @db.Uuid
  tenantId   String    @map("tenant_id") @db.Uuid
  studentId  String    @map("student_id") @db.Uuid
  groupId    String    @map("group_id") @db.Uuid
  roleCode   String?   @map("role_code") @db.VarChar(50)
  isPrimary  Boolean   @default(true) @map("is_primary")
  startDate  DateTime? @map("start_date") @db.Date
  endDate    DateTime? @map("end_date") @db.Date
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  group   Group   @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([studentId, isPrimary])
  @@map("student_group_assignments")
}

model StudentDormAssignment {
  id           String    @id @default(uuid()) @db.Uuid
  tenantId     String    @map("tenant_id") @db.Uuid
  studentId    String    @map("student_id") @db.Uuid
  dormitoryId  String    @map("dormitory_id") @db.Uuid
  isPrimary    Boolean   @default(true) @map("is_primary")
  startDate    DateTime? @map("start_date") @db.Date
  endDate      DateTime? @map("end_date") @db.Date
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  student   Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  dormitory Dormitory @relation(fields: [dormitoryId], references: [id], onDelete: Cascade)

  @@index([studentId, isPrimary])
  @@map("student_dorm_assignments")
}

model StudentPositionAssignment {
  id         String    @id @default(uuid()) @db.Uuid
  tenantId   String    @map("tenant_id") @db.Uuid
  studentId  String    @map("student_id") @db.Uuid
  positionId String    @map("position_id") @db.Uuid
  startDate  DateTime? @map("start_date") @db.Date
  endDate    DateTime? @map("end_date") @db.Date
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  student  Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  position Position @relation(fields: [positionId], references: [id], onDelete: Cascade)

  @@unique([studentId, positionId, startDate])
  @@map("student_position_assignments")
}

model PointAccount {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String   @map("tenant_id") @db.Uuid
  studentId     String   @unique @map("student_id") @db.Uuid
  totalPoints   Decimal  @default(0) @map("total_points") @db.Decimal(12, 2)
  balancePoints Decimal  @default(0) @map("balance_points") @db.Decimal(12, 2)
  penaltyPoints Decimal  @default(0) @map("penalty_points") @db.Decimal(12, 2)
  version       Int      @default(0)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant   Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  student  Student            @relation(fields: [studentId], references: [id], onDelete: Cascade)
  txs      PointTransaction[]

  @@map("point_accounts")
}

model PointReasonTemplate {
  id              String   @id @default(uuid()) @db.Uuid
  tenantId        String   @map("tenant_id") @db.Uuid
  classId         String   @map("class_id") @db.Uuid
  name            String   @db.VarChar(150)
  value           Decimal  @db.Decimal(12, 2)
  transactionType TransactionType @map("transaction_type")
  scene           String   @db.VarChar(50)
  category        String   @db.VarChar(50)
  note            String?
  isEditable      Boolean  @default(false) @map("is_editable")
  isMultiplier    Boolean  @default(false) @map("is_multiplier")
  multiplier      Decimal? @db.Decimal(12, 2)
  isActive        Boolean  @default(true) @map("is_active")
  displayOrder    Int      @default(0) @map("display_order")
  legacyName      String?  @map("legacy_name") @db.VarChar(150)
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  class  Class  @relation(fields: [classId], references: [id], onDelete: Cascade)
  txs    PointTransaction[]

  @@unique([classId, name])
  @@map("point_reason_templates")
}

model PointTransaction {
  id                      String          @id @default(uuid()) @db.Uuid
  tenantId                String          @map("tenant_id") @db.Uuid
  classId                 String          @map("class_id") @db.Uuid
  studentId               String          @map("student_id") @db.Uuid
  pointAccountId          String          @map("point_account_id") @db.Uuid
  transactionType         TransactionType @map("transaction_type")
  value                   Decimal         @db.Decimal(12, 2)
  reason                  String
  scene                   String          @db.VarChar(50)
  category                String          @db.VarChar(50)
  sourceModule            String          @map("source_module") @db.VarChar(50)
  sourceType              String?         @map("source_type") @db.VarChar(50)
  sourceId                String?         @map("source_id") @db.Uuid
  batchId                 String?         @map("batch_id") @db.Uuid
  reasonTemplateId        String?         @map("reason_template_id") @db.Uuid
  actorUserId             String?         @map("actor_user_id") @db.Uuid
  actorMembershipId       String?         @map("actor_membership_id") @db.Uuid
  occurredAt              DateTime        @map("occurred_at") @db.Timestamptz(6)
  isReverted              Boolean         @default(false) @map("is_reverted")
  revertedByTransactionId String?         @map("reverted_by_transaction_id") @db.Uuid
  legacyNumericId         Decimal?        @map("legacy_numeric_id") @db.Decimal(20, 4)
  legacySnapshot          Json?           @map("legacy_snapshot")
  metadata                Json            @default("{}")
  createdAt               DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant          Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  class           Class                @relation(fields: [classId], references: [id], onDelete: Cascade)
  student         Student              @relation(fields: [studentId], references: [id], onDelete: Cascade)
  pointAccount    PointAccount         @relation(fields: [pointAccountId], references: [id], onDelete: Cascade)
  reasonTemplate  PointReasonTemplate? @relation(fields: [reasonTemplateId], references: [id], onDelete: SetNull)
  actorUser       User?                @relation("PointTransactionActorUser", fields: [actorUserId], references: [id], onDelete: SetNull)
  actorMembership Membership?          @relation("PointTransactionActorMembership", fields: [actorMembershipId], references: [id], onDelete: SetNull)

  @@index([studentId, occurredAt(sort: Desc)])
  @@index([classId, occurredAt(sort: Desc)])
  @@index([sourceModule, sourceId])
  @@map("point_transactions")
}

model AttendancePolicy {
  id                          String   @id @default(uuid()) @db.Uuid
  tenantId                    String   @map("tenant_id") @db.Uuid
  classId                     String   @unique @map("class_id") @db.Uuid
  latePenaltyValue            Decimal  @default(-1) @map("late_penalty_value") @db.Decimal(12, 2)
  absentPenaltyValue          Decimal  @default(-5) @map("absent_penalty_value") @db.Decimal(12, 2)
  perfectAttendanceBonusValue Decimal  @default(10) @map("perfect_attendance_bonus_value") @db.Decimal(12, 2)
  weekendRules                Json     @default("{}") @map("weekend_rules")
  specialRules                Json     @default("{}") @map("special_rules")
  isFrozen                    Boolean  @default(false) @map("is_frozen")
  createdAt                   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  class  Class  @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@map("attendance_policies")
}

model AttendanceSchedule {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  classId      String   @map("class_id") @db.Uuid
  code         String   @db.VarChar(50)
  name         String   @db.VarChar(120)
  startTime    DateTime @map("start_time") @db.Time(6)
  endTime      DateTime @map("end_time") @db.Time(6)
  lateTime     DateTime @map("late_time") @db.Time(6)
  displayOrder Int      @default(0) @map("display_order")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant   Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  class    Class               @relation(fields: [classId], references: [id], onDelete: Cascade)
  sessions AttendanceSession[]

  @@unique([classId, code])
  @@map("attendance_schedules")
}

model AttendanceSession {
  id             String                  @id @default(uuid()) @db.Uuid
  tenantId       String                  @map("tenant_id") @db.Uuid
  classId        String                  @map("class_id") @db.Uuid
  scheduleId     String                  @map("schedule_id") @db.Uuid
  sessionDate    DateTime                @map("session_date") @db.Date
  sessionCode    String                  @map("session_code") @db.VarChar(50)
  plannedStartAt DateTime?               @map("planned_start_at") @db.Timestamptz(6)
  plannedEndAt   DateTime?               @map("planned_end_at") @db.Timestamptz(6)
  lateDeadlineAt DateTime?               @map("late_deadline_at") @db.Timestamptz(6)
  status         AttendanceSessionStatus @default(open)
  createdAt      DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime                @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant   Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  class    Class              @relation(fields: [classId], references: [id], onDelete: Cascade)
  schedule AttendanceSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  records  AttendanceRecord[]

  @@unique([classId, sessionDate, sessionCode])
  @@map("attendance_sessions")
}

model AttendanceRecord {
  id                 String                 @id @default(uuid()) @db.Uuid
  tenantId           String                 @map("tenant_id") @db.Uuid
  classId            String                 @map("class_id") @db.Uuid
  attendanceSessionId String                @map("attendance_session_id") @db.Uuid
  studentId          String                 @map("student_id") @db.Uuid
  status             AttendanceRecordStatus
  checkInAt          DateTime?              @map("check_in_at") @db.Timestamptz(6)
  recordedAt         DateTime               @map("recorded_at") @db.Timestamptz(6)
  source             String                 @default("manual") @db.VarChar(30)
  note               String?
  pointTransactionId String?                @map("point_transaction_id") @db.Uuid
  batchId            String?                @map("batch_id") @db.Uuid
  actorUserId        String?                @map("actor_user_id") @db.Uuid
  actorMembershipId  String?                @map("actor_membership_id") @db.Uuid
  legacyStudentName  String?                @map("legacy_student_name") @db.VarChar(120)
  legacyTimestamp    BigInt?                @map("legacy_timestamp")
  createdAt          DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime               @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant          Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  class           Class             @relation(fields: [classId], references: [id], onDelete: Cascade)
  session         AttendanceSession @relation(fields: [attendanceSessionId], references: [id], onDelete: Cascade)
  student         Student           @relation(fields: [studentId], references: [id], onDelete: Cascade)
  actorUser       User?             @relation("AttendanceRecordActorUser", fields: [actorUserId], references: [id], onDelete: SetNull)
  actorMembership Membership?       @relation("AttendanceRecordActorMembership", fields: [actorMembershipId], references: [id], onDelete: SetNull)

  @@unique([attendanceSessionId, studentId])
  @@map("attendance_records")
}

model ClassConfig {
  classId          String   @id @map("class_id") @db.Uuid
  tenantId         String   @map("tenant_id") @db.Uuid
  className        String   @map("class_name") @db.VarChar(120)
  timezone         String   @default("Asia/Shanghai") @db.VarChar(50)
  isFrozen         Boolean  @default(false) @map("is_frozen")
  scheduleNotes    Json     @default("{}") @map("schedule_notes")
  countdownEvents  Json     @default("[]") @map("countdown_events")
  extra            Json     @default("{}")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  class  Class  @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@map("class_configs")
}

model FeatureFlag {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  classId   String?  @map("class_id") @db.Uuid
  code      String   @db.VarChar(80)
  enabled   Boolean  @default(false)
  config    Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  class  Class? @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@unique([tenantId, classId, code])
  @@map("feature_flags")
}

model AuditLog {
  id                String   @id @default(uuid()) @db.Uuid
  tenantId          String?  @map("tenant_id") @db.Uuid
  classId           String?  @map("class_id") @db.Uuid
  actorUserId       String?  @map("actor_user_id") @db.Uuid
  actorMembershipId String?  @map("actor_membership_id") @db.Uuid
  action            String   @db.VarChar(100)
  targetType        String   @map("target_type") @db.VarChar(100)
  targetId          String?  @map("target_id") @db.Uuid
  requestId         String?  @map("request_id") @db.VarChar(120)
  ip                String?  @db.Inet
  userAgent         String?  @map("user_agent")
  beforeData        Json?    @map("before_data")
  afterData         Json?    @map("after_data")
  metadata          Json     @default("{}")
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant           Tenant?     @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  class            Class?      @relation(fields: [classId], references: [id], onDelete: SetNull)
  actorUser        User?       @relation(fields: [actorUserId], references: [id], onDelete: SetNull)
  actorMembership  Membership? @relation(fields: [actorMembershipId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt(sort: Desc)])
  @@index([targetType, targetId, createdAt(sort: Desc)])
  @@map("audit_logs")
}

model ImportJob {
  id                String    @id @default(uuid()) @db.Uuid
  tenantId          String    @map("tenant_id") @db.Uuid
  classId           String?   @map("class_id") @db.Uuid
  jobType           String    @map("job_type") @db.VarChar(50)
  status            String    @db.VarChar(30)
  sourceFilename    String?   @map("source_filename") @db.VarChar(255)
  summary           Json      @default("{}")
  errorMessage      String?   @map("error_message")
  triggeredByUserId String?   @map("triggered_by_user_id") @db.Uuid
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  finishedAt        DateTime? @map("finished_at") @db.Timestamptz(6)

  tenant          Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  class           Class? @relation(fields: [classId], references: [id], onDelete: SetNull)
  triggeredByUser User?  @relation(fields: [triggeredByUserId], references: [id], onDelete: SetNull)

  @@map("import_jobs")
}

model ExportJob {
  id                      String    @id @default(uuid()) @db.Uuid
  tenantId                String    @map("tenant_id") @db.Uuid
  classId                 String?   @map("class_id") @db.Uuid
  requestedByUserId       String?   @map("requested_by_user_id") @db.Uuid
  requestedByMembershipId String?   @map("requested_by_membership_id") @db.Uuid
  jobType                 String    @map("job_type") @db.VarChar(50)
  exportType              String    @map("export_type") @db.VarChar(50)
  filters                 Json      @default("{}")
  status                  String    @db.VarChar(30)
  outputPath              String?   @map("output_path") @db.VarChar(500)
  manifestEntry           Json?     @map("manifest_entry")
  summary                 Json      @default("{}")
  errorMessage            String?   @map("error_message")
  startedAt               DateTime? @map("started_at") @db.Timestamptz(6)
  finishedAt              DateTime? @map("finished_at") @db.Timestamptz(6)
  expiresAt               DateTime? @map("expires_at") @db.Timestamptz(6)
  createdAt               DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt               DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant                Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  class                 Class?      @relation(fields: [classId], references: [id], onDelete: SetNull)
  requestedByUser       User?       @relation("ExportJobRequestedByUser", fields: [requestedByUserId], references: [id], onDelete: SetNull)
  requestedByMembership Membership? @relation(fields: [requestedByMembershipId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt(sort: Desc)])
  @@index([classId, createdAt(sort: Desc)])
  @@index([status, createdAt(sort: Desc)])
  @@map("export_jobs")
}

model MigrationMapping {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  entityType  String   @map("entity_type") @db.VarChar(80)
  legacyScope String   @map("legacy_scope") @db.VarChar(80)
  legacyKey   String   @map("legacy_key") @db.VarChar(255)
  newId       String   @map("new_id") @db.Uuid
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, entityType, legacyScope, legacyKey])
  @@map("migration_mappings")
}
