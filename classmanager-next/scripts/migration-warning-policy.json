{
  "version": 1,
  "rules": [
    {
      "matchType": "code",
      "pattern": "pointAccount.missing_student",
      "severity": "blocker",
      "action": "stop_import"
    },
    {
      "matchType": "code",
      "pattern": "groupAssignment.missing_student",
      "severity": "blocker",
      "action": "stop_import"
    },
    {
      "matchType": "code",
      "pattern": "groupAssignment.missing_group",
      "severity": "blocker",
      "action": "stop_import"
    },
    {
      "matchType": "code",
      "pattern": "dormAssignment.missing_student",
      "severity": "blocker",
      "action": "stop_import"
    },
    {
      "matchType": "code",
      "pattern": "dormAssignment.missing_dorm",
      "severity": "blocker",
      "action": "stop_import"
    },
    {
      "matchType": "code",
      "pattern": "positionAssignment.missing_student",
      "severity": "blocker",
      "action": "stop_import"
    },
    {
      "matchType": "code",
      "pattern": "positionAssignment.missing_position",
      "severity": "blocker",
      "action": "stop_import"
    },
    {
      "matchType": "code",
      "pattern": "pointTransaction.missing_student",
      "severity": "blocker",
      "action": "stop_import"
    },
    {
      "matchType": "code",
      "pattern": "attendanceRecord.missing_student",
      "severity": "blocker",
      "action": "stop_import"
    },
    {
      "matchType": "code",
      "pattern": "attendanceRecord.missing_session",
      "severity": "blocker",
      "action": "stop_import"
    },
    {
      "matchType": "code",
      "pattern": "attendancePolicy.weekend_rule_invalid",
      "severity": "blocker",
      "action": "stop_import"
    },
    {
      "matchType": "code",
      "pattern": "attendancePolicy.weekend_rule_missing_schedule",
      "severity": "blocker",
      "action": "stop_import"
    },
    {
      "matchType": "code",
      "pattern": "attendancePolicy.special_rule_missing_schedule",
      "severity": "blocker",
      "action": "stop_import"
    },
    {
      "matchType": "code",
      "pattern": "attendancePolicy.special_rule_invalid_time",
      "severity": "blocker",
      "action": "stop_import"
    },
    {
      "matchType": "message_contains",
      "pattern": "Attendance entry could not resolve student id",
      "severity": "review",
      "action": "skip_record_and_report"
    },
    {
      "matchType": "message_contains",
      "pattern": "Attendance entry skipped by mapping",
      "severity": "info",
      "action": "accepted_skip_after_manual_review"
    },
    {
      "matchType": "message_contains",
      "pattern": "contains base64 avatar data",
      "severity": "info",
      "action": "defer_asset_migration"
    },
    {
      "matchType": "message_contains",
      "pattern": "Commissioner",
      "severity": "review",
      "action": "skip_assignment_and_report"
    }
  ]
}
