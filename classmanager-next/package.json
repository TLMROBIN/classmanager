{
  "name": "classmanager-next",
  "private": true,
  "version": "0.1.0",
  "description": "Rebuild workspace for the next generation class manager system",
  "packageManager": "npm@10",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "dev:web": "npm run dev -w @classmanager/web",
    "dev:api": "npm run dev -w @classmanager/api",
    "dev:admin": "npm run dev -w @classmanager/admin",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "legacy:export": "node ./scripts/export-legacy-data.js",
    "legacy:attendance-template": "node ./scripts/build-attendance-name-mapping-template.js",
    "legacy:attendance-prepare": "node ./scripts/prepare-attendance-name-mapping.js",
    "legacy:attendance-validate": "node ./scripts/validate-attendance-name-mapping.js",
    "legacy:transform": "node ./scripts/transform-legacy-user.js --all",
    "legacy:resync": "node ./scripts/resync-legacy-user.js",
    "legacy:resync:batch": "node ./scripts/resync-legacy-batch.js",
    "backup:restore:full": "node ./scripts/restore-structured-full.js",
    "legacy:enable-login": "node ./scripts/enable-migrated-login.js",
    "roles:backfill": "node ./scripts/backfill-membership-roles.js",
    "export:structured": "node ./scripts/export-structured-data.js",
    "export:cleanup": "node ./scripts/cleanup-export-jobs.js",
    "admin:cleanup:regression": "node ./scripts/cleanup-admin-regression-users.js",
    "homework:cleanup:regression": "node ./scripts/cleanup-homework-regression-records.js",
    "normalized:validate": "node ./scripts/validate-normalized-data.js --all",
    "normalized:load:dry-run": "node ./scripts/load-normalized-data.js --input ./out/normalized/0010-14ban.normalized.json",
    "safe-subset:dry-run": "node ./scripts/load-safe-subset.js --input ./out/normalized/0010-14ban.normalized.json",
    "attendance:phase2:dry-run": "node ./scripts/load-attendance-phase2.js --input ./out/normalized/0010-14ban.normalized.json",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "prisma:generate": "prisma generate --schema ./prisma/schema.prisma",
    "prisma:migrate:dev": "prisma migrate dev --schema ./prisma/schema.prisma",
    "prisma:migrate:deploy": "prisma migrate deploy --schema ./prisma/schema.prisma",
    "prisma:seed": "tsx ./prisma/seed.ts",
    "prisma:validate": "prisma validate --schema ./prisma/schema.prisma",
    "prisma:format": "prisma format --schema ./prisma/schema.prisma"
  },
  "devDependencies": {
    "@prisma/client": "^6.6.0",
    "bcryptjs": "^3.0.2",
    "prisma": "^6.6.0",
    "tsx": "^4.19.3"
  }
}
